# Pbooth — env file template
#
# Copy this file to ONE of the following based on your workflow:
#
#   .env.development         loaded by `npm run dev`        (sandbox)
#   .env.production          loaded by `npm run build`      (production)
#   .env                     fallback for both modes
#   .env.development.local   personal override on top of .env.development
#   .env.production.local    personal override on top of .env.production
#
# All `.env*` files are gitignored — none of them are committed. Real
# values are kept locally on each developer machine / kiosk install.
#
# Sensitive credentials (DOKU Client ID, Secret Key, RSA keys, Supabase
# service role key) live in Supabase Edge Function secrets and are
# never read by the kiosk bundle.

# ─── Supabase (required) ────────────────────────────────────────────────────
# Public values — both end up in the kiosk JS bundle. Anon key is
# RLS-protected so it's safe to embed.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ─── Camera (optional, default 'webcam') ───────────────────────────────────
# Options: 'webcam' | 'dslr'
#   webcam = USB webcam / HDMI capture card via getUserMedia (dev, or an
#            EOS M3 HDMI-grab kiosk — no flash)
#   dslr   = Canon EOS DSLR (e.g. EOS 800D) tethered via digiCamControl: real
#            mechanical-shutter stills so the pop-up flash fires + full-res.
#            HDMI capture card still used for the live preview.
# NOTE: baked in at BUILD time — set before `npm run build`, not on the kiosk.
# See docs/kiosk-setup-800d.md.
VITE_CAMERA_SOURCE=webcam
# digiCamControl HTTP webserver (only used when VITE_CAMERA_SOURCE=dslr):
# VITE_DCC_URL=http://localhost:5513
# VITE_DCC_ISO=800
# VITE_DCC_SHUTTER=1/125     # keep <= 1/200 (flash X-sync on the 800D)
# VITE_DCC_APERTURE=8
# VITE_DCC_WB=Flash
# VITE_DCC_FALLBACK=true     # degrade to HDMI snapshot if digiCamControl is down
# Polling and request timeout for camera capture, in ms (default 12000)
# VITE_DCC_CAPTURE_TIMEOUT_MS=12000

# ─── Payment provider (required) ────────────────────────────────────────────
# Options: 'mock' | 'doku'
#   mock = auto-resolves in 3 s, no DOKU calls (offline UI work)
#   doku = real DOKU Checkout via the create-doku-payment edge function
VITE_PAYMENT_PROVIDER=doku

# ─── Optional ───────────────────────────────────────────────────────────────
# Override the create-doku-payment edge function URL. Leave blank to
# derive from VITE_SUPABASE_URL.
# VITE_DOKU_CREATE_URL=

# Show "DEV: SIMULATE PAID" button in built development mode
# VITE_DEV_SKIP_BUTTON=true

# Override the share page base URL (used to build phone-scannable URLs
# from Electron, where window.location.origin is `file://`).
# VITE_SHARE_BASE_URL=https://your-share-domain.example

# Countdown seconds before each DSLR capture (increase to 7 or 8 for slow flash reload)
# VITE_CAPTURE_COUNTDOWN_SEC=5

# ─── Printer (optional, default 'DS-RX1') ───────────────────────────────────
# Two Windows queues for the same physical DS-RX1.
# VITE_PRINTER_FULL_NAME=PBOOTH DS-RX1 FULL
# VITE_PRINTER_CUT_NAME=PBOOTH DS-RX1 CUT
# Legacy single-queue fallback: VITE_PRINTER_NAME=DS-RX1
# Silent print (true = print directly, false = show OS print dialog for debugging)
# VITE_PRINTER_SILENT=true
# Orientation (true = landscape, false = portrait) for printers like DNP
# VITE_PRINTER_LANDSCAPE=true
# Rotation in degrees (0, 90, 180, 270) to align portrait layout on landscape roll
# VITE_PRINTER_ROTATION=90

# ─── Storage Backend (optional) ─────────────────────────────────────────────
# Options: 'supabase' | 'r2'
#   supabase = use Supabase Storage (default)
#   r2 = use private Cloudflare R2 via Supabase Edge Functions
VITE_STORAGE_BACKEND=r2

# ─── Admin Gallery (optional) ───────────────────────────────────────────────
# /admin uses Supabase Auth email/password. Add the user's UUID to
# public.admin_users; no admin password or service-role key belongs in Vite.

# R2 credentials, DOKU secrets, CLEANUP_CRON_SECRET, and the Supabase
# service-role key must be configured only as Supabase Edge Function secrets.
